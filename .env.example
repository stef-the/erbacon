# Copy this file to ".env" and fill in real values for local development.
# In production, set these same keys in the Cloudflare Pages dashboard
# (Settings → Environment variables).
#
# Each page reads ONE tab of the Google Sheet.
#   _SHEET_ID  = the long id in the sheet URL: docs.google.com/spreadsheets/d/<THIS>/edit
#   _SHEET_GID = the "gid=<number>" of the specific tab that page should read
#
# IMPORTANT: a tab's GID stays the same when you RENAME it, but it CHANGES if you
# delete and recreate the tab. If a page suddenly goes blank, a GID probably changed
# and needs updating here (and in Cloudflare), followed by a redeploy.
#
# The sheet must be readable: File → Share → Anyone with the link → Viewer.

# New Equipment page  (/products/construction)
CONSTRUCTION_PRODUCTS_SHEET_ID=your_sheet_id_here
CONSTRUCTION_PRODUCTS_SHEET_GID=your_sheet_gid_here

# Used Equipment page  (/products/used)
USED_EQUIPMENT_SHEET_ID=your_sheet_id_here
USED_EQUIPMENT_SHEET_GID=your_sheet_gid_here

# Truck Equipment page  (/products/trucks)
TRUCK_EQUIPMENT_SHEET_ID=your_sheet_id_here
TRUCK_EQUIPMENT_SHEET_GID=your_sheet_gid_here

# Site Services – Fence Rental page  (/services/project-site)
PROJECT_SITE_SERVICES_SHEET_ID=your_sheet_id_here
PROJECT_SITE_SERVICES_SHEET_GID=your_sheet_gid_here

# Fencing page  (/services/fencing — exists but not currently linked in the menu)
TEMPORARY_FENCING_SHEET_ID=your_sheet_id_here
TEMPORARY_FENCING_SHEET_GID=your_sheet_gid_here
